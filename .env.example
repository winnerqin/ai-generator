# AI 图片生成器配置文件
# 请将此文件复制为 .env 并填入您的密钥
#
# 配置方法：
# 1. 复制此文件：copy .env.example .env (Windows) 或 cp .env.example .env (Linux/Mac)
# 2. 在下方填入您的实际密钥
# 3. 保存文件
#
# ============ 火山引擎视觉 API 配置（必需）============
# 获取密钥：https://console.volcengine.com/iam/keymanage/
VOLCENGINE_AK=your_access_key_here
VOLCENGINE_SK=your_secret_key_here
ARK_ASSET_REGION=cn-beijing
ARK_ASSET_SERVICE=ark
ARK_ASSET_HOST=open.volcengineapi.com
ARK_ASSET_VERSION=2024-01-01
ARK_ASSET_TIMEOUT_SECONDS=15
ARK_API_KEY=your_ark_api_key_here
# 多上游 Key 池（可选）：多个 Key 用英文逗号分隔；配置后全能视频会按稳定哈希分流
# 不配置时默认回退到上面的单 ARK_API_KEY
ARK_API_KEY_POOL=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ============ OpenAI Image2 生图配置（gpt-image-2）============
IMAGE2_OPENAI_BASE_URL=https://api.openai.com/v1
IMAGE2_OPENAI_API_KEY=your_image2_openai_api_key_here

# 图片生成模型名称（支持：doubao-seedreen-4-5-251128, doubao-seedreen-4-0 等）
SEEDREAM_MODEL=doubao-seedream-4-5-251128

SEEDANCE_OMNI_MODEL=doubao-seedance-2-0-260128
SEEDANCE_OMNI_CREATE_PATH=/contents/generations/tasks
SEEDANCE_OMNI_QUERY_PATH=/contents/generations/tasks/{task_id}
SEEDANCE_OMNI_LIST_PATH=/contents/generations/tasks
SEEDANCE_OMNI_CANCEL_PATH=/contents/generations/tasks/{task_id}

# ============ 火山方舟国际版配置（Seedance 国际版）============
# 国际版 API 调用地址
ARK_INTL_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# 国际版 API Key（需要填写实际值）
ARK_INTL_API_KEY=your_intl_api_key_here
# 国际版多上游 Key 池（可选）：多个 Key 用英文逗号分隔
# 不配置时默认回退到上面的单 ARK_INTL_API_KEY
ARK_INTL_API_KEY_POOL=
# 国际版模型名称
SEEDANCE_INTL_MODEL=dreamina-seedance-2-0-260128

# ============ 视频画质增强配置 ============
# 用于视频画质增强功能，提升视频分辨率
VIDEO_ENHANCE_API_KEY=your_video_enhance_api_key_here
VIDEO_ENHANCE_BASE_URL=https://amk.cn-beijing.volces.com/api/v1
VIDEO_ENHANCE_CREATE_PATH=/tools/enhance-video
VIDEO_ENHANCE_QUERY_PATH=/tasks/{task_id}

# ============ 支付中心配置（用户余额充值）============
PUBLIC_BASE_URL=http://127.0.0.1:8090
PAYMENT_CENTER_ENABLED=false
PAYMENT_CENTER_BASE_URL=
PAYMENT_CENTER_CREATE_ORDER_PATH=/api/internal/payments/wechat/native-orders
PAYMENT_CENTER_MERCHANT_ID=
PAYMENT_CENTER_APP_ID=
PAYMENT_CENTER_SIGN_SECRET=
PAYMENT_CENTER_TIMEOUT_SECONDS=15
PAYMENT_CENTER_NOTIFY_PATH=/api/payment-center/recharge-callback
PAYMENT_CENTER_ALLOWED_AMOUNTS=100,500,1000
PAYMENT_CENTER_MIN_RECHARGE_CENT=10000
PAYMENT_CENTER_MAX_RECHARGE_CENT=5000000

# ============ Flask 运行配置 ============
FLASK_HOST=0.0.0.0
FLASK_PORT=8090
FLASK_DEBUG=false

# ============ 阿里云 OSS 配置（可选）============
# 仅在使用参考图片（图生图）功能时需要配置
# 如果只使用文字生成图片，无需配置此部分
# 获取密钥：https://ram.console.aliyun.com/manage/ak

# 启用 OSS 上传（true/false）
OSS_ENABLED=false

# OSS 端点地址（格式：bucket-name.oss-region.aliyuncs.com）
# 这是基础配置，用于显示和作为其他配置的默认值
OSS_ENDPOINT=shor-file.oss-cn-wulanchabu.aliyuncs.com

# 外网端点（用于返回给前端的URL）
# 如果不设置，将使用 OSS_ENDPOINT 的值
# 外网用户通过此地址访问图片
OSS_EXTERNAL_ENDPOINT=

# 服务器内部访问端点（用于OSS SDK连接）
# 如果不设置，将使用 OSS_EXTERNAL_ENDPOINT 或 OSS_ENDPOINT 的值
# 在阿里云内网环境中，可设置为内网地址以节省流量费用，如：
# bucket-name.oss-cn-region-internal.aliyuncs.com
OSS_ACCESS_ENDPOINT=

# 阿里云 AccessKey
OSS_ACCESS_KEY_ID=your_aliyun_access_key_id
OSS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# ============ 数据库类型配置 ============
# 仅支持 MySQL 8.0
DB_TYPE=mysql

# ============ MySQL 8.0 数据库配置 ============
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=ai_app
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=ai_generator
MYSQL_CHARSET=utf8mb4
